	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "foreground": "#545B6B", "fontStyle": "italic" }
		},
		{
			"scope": ["keyword", "keyword.control", "storage.type", "storage.modifier", "keyword.operator.new", "keyword.operator.expression"],
			"settings": { "foreground": "#9FD17A" }
		},
		{
			"scope": ["keyword.operator"],
			"settings": { "foreground": "#8E98AD" }
		},
		{
			"scope": ["string", "string.quoted", "string.template", "constant.other.symbol"],
			"settings": { "foreground": "#D8C68C" }
		},
		{
			"scope": ["constant.numeric", "constant.language", "constant.language.boolean", "constant.language.null"],
			"settings": { "foreground": "#F0B97A" }
		},
		{
			"scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
			"settings": { "foreground": "#C2F24D" }
		},
		{
			"scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.name.namespace", "storage.type.class"],
			"settings": { "foreground": "#7FD0C0" }
		},
		{
			"scope": ["variable", "variable.other", "variable.parameter", "meta.definition.variable"],
			"settings": { "foreground": "#CCD5E6" }
		},
		{
			"scope": ["variable.other.property", "meta.object-literal.key", "support.variable.property"],
			"settings": { "foreground": "#AEBBD0" }
		},
		{
			"scope": ["entity.name.tag", "punctuation.definition.tag"],
			"settings": { "foreground": "#9FD17A" }
		},
		{
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#C2D98A" }
		},
		{
			"scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
			"settings": { "foreground": "#6B7488" }
		},
		{
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#FF3B57" }
		}
	]
}
